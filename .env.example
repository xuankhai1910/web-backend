PORT=3000
NODE_ENV=production

# MongoDB Atlas connection string
# Lấy từ Atlas -> Database -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/web-backend?retryWrites=true&w=majority

# JWT
JWT_ACCESS_TOKEN_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRE=1h
JWT_REFRESH_TOKEN_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRE=7d

# CORS: danh sách origin cho phép, ngăn cách bởi dấu phẩy
# Ví dụ: https://my-frontend.com,https://admin.my-frontend.com
CORS_ORIGINS=

# DB init seed (chỉ bật 1 lần khi DB trống, sau đó phải đổi về false)
SHOULD_INIT=false
INIT_PASSWORD=change_me

# Mail
EMAIL_HOST=smtp.gmail.com
EMAIL_AUTH_USER=
EMAIL_AUTH_PASSWORD=
EMAIL_PREVIEW=false

# Google Gemini
GEMINI_API_KEY=
